# n8n Instance Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env — use .gitignore to prevent accidental commits

N8N_HOST=http://localhost:5678
N8N_API_KEY=your_n8n_api_key_here
N8N_PROJECT_ID=
N8N_PROJECT_NAME=Personal

# Optional: Sync folder for n8nac
N8N_SYNC_FOLDER=workflows

# Claude/LLM Configuration (if using external APIs)
ANTHROPIC_API_KEY=your_claude_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Development environment
NODE_ENV=development
DEBUG=false

# Optional: Superpowers configuration
SUPERPOWERS_ENABLED=true
